\
    /**\
     * Compute Th\'e1\'ba\'a7n S\uc0\u258 \'a1t for a given palace position.\
     * @param \{number\} yearChi - Year branch (0-11)\
     * @param \{number\} dayChi  - Day branch (0-11)\
     * @param \{number\} dayCan  - Day stem (0-9)\
     * @param \{number\} tbBranch - Thi\uc0\u258 \'aan B\u258 \'a0n branch at this position (0-11)\
     * @returns \{string[]\} List of Th\'e1\'ba\'a7n S\uc0\u258 \'a1t names at this position\
     */\
    function getThanSat(yearChi, dayChi, dayCan, tbBranch) \{\
        var sats = [];\
\
        // \'e2\'94\'80\'e2\'94\'80 Main: V\uc0\u258 \'b2ng Th\u258 \'a1i Tu\'e1\'ba\'bf (1 star per cell, TB-based) \'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\
        var vttIdx = (tbBranch - yearChi + 12) % 12;\
        sats.push(VONG_THAI_TUE[vttIdx]);\
\
        // \'e2\'94\'80\'e2\'94\'80 Additional stars (TB-based) \'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\
        var tamHopKey = [2, 1, 0, 3, 2, 1, 0, 3, 2, 1, 0, 3];\
\
        // Thi\uc0\u258 \'aan M\u258 \'a3 (\'e9\'a9\'9b\'e9\'a6\'ac) \'e2\'80\'94 day branch Tam H\'e1\'bb\'a3p Tr\'c6\'b0\'e1\'bb\u157 ng Sinh\
        var maPositions = [8, 11, 2, 5]; // H\'e1\'bb\uc0\u143 a\'e2\'86\'92Th\u258 \'a2n, Kim\'e2\'86\'92H\'e1\'bb\'a3i, Th\'e1\'bb\'a7y\'e2\'86\'92D\'e1\'ba\'a7n, M\'e1\'bb\'99c\'e2\'86\'92T\'e1\'bb\'b5\
        if (tbBranch === maPositions[tamHopKey[dayChi]]) sats.push('Thi\uc0\u258 \'aan M\u258 \'a3');\
\
        // \'c4\uc0\u144 \u258 \'a0o Hoa (\'e6\'a1\'83\'e8\u138 \'b1) \'e2\'80\'94 day branch Tam H\'e1\'bb\'a3p M\'e1\'bb\'99c D\'e1\'bb\'a5c\
        var daoHoaPos = [9, 6, 3, 0];\
        if (tbBranch === daoHoaPos[tamHopKey[dayChi]]) sats.push('\'c4\uc0\u144 \u258 \'a0o Hoa');\
\
        // Hoa C\uc0\u258 \'a1i (\'e8\u143 \'af\'e8\'93\'8b) \'e2\'80\'94 day branch Tam H\'e1\'bb\'a3p M\'e1\'bb\'99\
        var hoaCaiPos = [10, 1, 4, 7];\
        if (tbBranch === hoaCaiPos[tamHopKey[dayChi]]) sats.push('Hoa C\uc0\u258 \'a1i');\
\
        // \'c4\uc0\u144 \'e1\'ba\'a1i S\u258 \'a1t (\'e5\'a4\'a7\'e7\'85\u158 ) \'e2\'80\'94 year branch Tam H\'e1\'bb\'a3p M\'e1\'bb\'99\
        var yearTHKey = tamHopKey[yearChi];\
        var daiSatPos = [10, 1, 4, 7]; // Same positions as Hoa C\uc0\u258 \'a1i\
        if (tbBranch === daiSatPos[yearTHKey]) sats.push('\'c4\uc0\u144 \'e1\'ba\'a1i S\u258 \'a1t');\
\
        // Thi\uc0\u258 \'aan H\u258 \'acnh (\'e5\'a4\'a9\'e5\'88\'91) \'e2\'80\'94 day branch H\u258 \'acnh (punishment)\
        var hinhMap = [3, 10, 5, 0, 4, 2, 6, 1, 2, 9, 7, 11];\
        if (tbBranch === hinhMap[dayChi]) sats.push('Thi\uc0\u258 \'aan H\u258 \'acnh');\
\
        // Du \'c4\uc0\u144 \u258 \'b4 (\'e9\u129 \u138 \'e9\'83\'bd) \'e2\'80\'94 yearChi + 7 (coincides with Long \'c4\u144 \'e1\'bb\'a9c position)\
        // Only show as extra label if it doesn't duplicate the main VTT star\
        if (tbBranch === (yearChi + 7) % 12 && vttIdx !== 7) sats.push('Du \'c4\uc0\u144 \u258 \'b4');\
\
        // Thi\uc0\u258 \'aan L\'e1\'bb\'99c (\'e5\'a4\'a9\'e7\'a5\'bf/\'e7\'a5\'bf\'e7\'a5\u158 ) \'e2\'80\'94 L\'e1\'bb\'99c of Day Stem\
        var lucPos = [2, 3, 5, 6, 5, 6, 8, 9, 11, 0]; // Gi\uc0\u258 \'a1p\'e2\'86\'92D\'e1\'ba\'a7n, \'e1\'ba\'a4t\'e2\'86\'92M\u258 \'a3o...\
        if (tbBranch === lucPos[dayCan]) sats.push('Thi\uc0\u258 \'aan L\'e1\'bb\'99c');\
\
        return sats;\
    \}\
\
    // ============================================================\
    //  MAIN CALCULATE\
    // ============================================================\
\
    function calculate(viewDate, viewHour, viewMinute, birthDate, birthHour, birthMinute, gender) \{\
        viewHour = parseInt(viewHour) || 0;\
        viewMinute = parseInt(viewMinute) || 0;\
\
        var year = viewDate.getFullYear();\
        var month = viewDate.getMonth() + 1;\
        var day = viewDate.getDate();\
\
        // Handle 23:00+ \'e2\'86\'92 next day's T\uc0\u258 \'bd hour\
        var effectiveYear = year, effectiveMonth = month, effectiveDay = day;\
        if (viewHour >= 23) \{\
            var nextDay = new Date(year, month - 1, day + 1);\
            effectiveYear = nextDay.getFullYear();\
            effectiveMonth = nextDay.getMonth() + 1;\
            effectiveDay = nextDay.getDate();\
        \}\
\
        // Solar term (using original date for term lookup)\
        var solarTerm = KMDG_Solar.getCurrentSolarTerm(viewDate, viewHour, viewMinute);\
\
        // Four Pillars \'e2\'80\'94 using effective date for 23:00+ shift for Day Pillar\
        // Year and Month pillars use EXACT time (un-shifted) to compare with solar terms\
        var yearCC = getYearCanChi(year, month, day, viewHour, viewMinute);\
        var monthCC = getMonthCanChi(yearCC.can, solarTerm.name);\
        var dayCC = getDayCanChi(effectiveYear, effectiveMonth, effectiveDay);\
\
        var hourChi = getHourChi(viewHour);\
        var hourCan = getHourCan(dayCC.can, hourChi);\
        var hourCC = \{ can: hourCan, chi: hourChi, jiaZi: getJiaZiIndex(hourCan, hourChi) \};\
        \
        // Birth Pillars & KW (optional \'e2\'80\'94 only if birthDate provided)\
        var birthPillars = null;\
        var birthKW = null;\
        if (birthDate) \{\
            var byy = birthDate.getFullYear();\
            var bmm = birthDate.getMonth() + 1;\
            var bdd = birthDate.getDate();\
            var bhh = birthHour || 0;\
            var bmin = birthMinute || 0;\
            \
            // Handle 23:00+ \'e2\'86\'92 next day's T\uc0\u258 \'bd hour for Birth Date\
            var effByy = byy, effBmm = bmm, effBdd = bdd;\
            if (bhh >= 23) \{\
                var bNextDay = new Date(byy, bmm - 1, bdd + 1);\
                effByy = bNextDay.getFullYear();\
                effBmm = bNextDay.getMonth() + 1;\
                effBdd = bNextDay.getDate();\
            \}\
\
            var bsolarTerm = KMDG_Solar.getCurrentSolarTerm(birthDate, bhh, bmin);\
            var byCC = getYearCanChi(byy, bmm, bdd, bhh, bmin); // Use exact time for Year Pillar\
            var bmCC = getMonthCanChi(byCC.can, bsolarTerm.name); // Month Pillar relies on exact solar term\
            var bdCC = getDayCanChi(effByy, effBmm, effBdd); // Day Pillar uses effective date\
            var bhChi = getHourChi(bhh);\
            var bhCan = getHourCan(bdCC.can, bhChi); // Hour Can relies on effective day Can\
            var bhCC = \{ can: bhCan, chi: bhChi, jiaZi: getJiaZiIndex(bhCan, bhChi) \};\
\
            birthPillars = \{ year: byCC, month: bmCC, day: bdCC, hour: bhCC \};\
            var birthKwYear = getKongWang(birthPillars.year.jiaZi);\
            var birthKwMonth = getKongWang(birthPillars.month.jiaZi);\
            var birthKwDay = getKongWang(birthPillars.day.jiaZi);\
            var birthKwHour = getKongWang(birthPillars.hour.jiaZi);\
            birthKW = \{ year: birthKwYear, month: birthKwMonth, day: birthKwDay, hour: birthKwHour \};\
        \}\
\
        // Nguy\'e1\'bb\'87t T\'c6\'b0\'e1\'bb\'9bng\
        var nguyetTuong = getNguyetTuong(year, month, day, viewHour, viewMinute);\
\
        // Thi\uc0\u258 \'aan B\u258 \'a0n\
        var thienBan = buildThienBan(nguyetTuong.branch, hourChi);\
\
        // Qu\uc0\u258 \'bd Nh\u258 \'a2n & Thi\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng\
        var quyNhanBranch = getQuyNhanBranch(dayCC.can, hourChi);\
        var thienTuong = buildThienTuong(quyNhanBranch, thienBan);\
\
        // T\'e1\'bb\'a9 Kh\uc0\u258 \'b3a\
        var tuKhoa = buildTuKhoa(dayCC.can, dayCC.chi, thienBan);\
\
        // Tam Truy\'e1\'bb\uc0\u129 n\
        var tamTruyen = buildTamTruyen(tuKhoa, dayCC.can, thienBan);\
\
        // Kh\uc0\u258 \'b4ng Vong for each pillar\
        var kvYear = getKongWang(yearCC.jiaZi);\
        var kvMonth = getKongWang(monthCC.jiaZi);\
        var kvDay = getKongWang(dayCC.jiaZi);\
        var kvHour = getKongWang(hourCC.jiaZi);\
\
        // Nguy\uc0\u258 \'aan determination (for L\'e1\'bb\'a5c Nh\u258 \'a2m: based on day's position in term)\
        var yuan = getYuan(dayCC.can, dayCC.chi);\
\
        // Build full palace data (12 positions)\
        var palaces = [];\
        var dayStemEl = CAN_ELEMENT[dayCC.can];\
        for (var p = 0; p < 12; p++) \{\
            var tbBranch = thienBan[p];\
            var generalIdx = thienTuong[tbBranch]; // Lookup by Thi\uc0\u258 \'aan B\u258 \'a0n branch\
            var lucThan = getLucThan(dayStemEl, CHI_ELEMENT[tbBranch]);\
            var truongSinh = getTruongSinh(dayCC.can, p);\
            var thanSat = getThanSat(yearCC.chi, dayCC.chi, dayCC.can, tbBranch);\
            var loaiThanIdx = getLoaiThan(dayCC.chi, p);\
\
            palaces[p] = \{\
                diBan: p,                          // \'c4\uc0\u144 \'e1\'bb\'8ba B\u258 \'a0n branch (fixed)\
                thienBan: tbBranch,                // Thi\uc0\u258 \'aan B\u258 \'a0n branch\
                thienBanName: DIA_CHI[tbBranch],\
                nguyetTuongName: NGUYET_TUONG_NAMES[p], // Name of this \'c4\uc0\u144 \'e1\'bb\'8ba B\u258 \'a0n branch\
                generalIdx: generalIdx !== undefined ? generalIdx : -1,\
                generalName: generalIdx !== undefined ? THIEN_TUONG[generalIdx].name : '',\
                lucThan: lucThan,\
                lucThanName: LUC_THAN_NAMES[lucThan],\
                loaiThan: loaiThanIdx,\
                loaiThanName: LOAI_THAN_NAMES[loaiThanIdx],\
                truongSinh: truongSinh,\
                truongSinhName: TRUONG_SINH_NAMES[truongSinh],\
                thanSat: thanSat\
            \};\
        \}\
\
        // Enrich T\'e1\'bb\'a9 Kh\uc0\u258 \'b3a with Thi\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng and L\'e1\'bb\'a5c Th\u258 \'a2n\
        for (var i = 0; i < 4; i++) \{\
            var tk = tuKhoa[i];\
            var ttIdx = thienTuong[tk.top];\
            tk.generalIdx = ttIdx !== undefined ? ttIdx : -1;\
            tk.generalName = ttIdx !== undefined ? THIEN_TUONG[ttIdx].name : '';\
            tk.lucThan = getLucThan(dayStemEl, CHI_ELEMENT[tk.top]);\
            tk.lucThanName = LUC_THAN_NAMES[tk.lucThan] || '';\
        \}\
\
        // Enrich Tam Truy\'e1\'bb\uc0\u129 n\
        var tamTruyenData = [\
            \{ label: 'S\'c6\'a1',   branch: tamTruyen.so \},\
            \{ label: 'Trung', branch: tamTruyen.trung \},\
            \{ label: 'M\'e1\'ba\'a1t',  branch: tamTruyen.mat \}\
        ];\
        for (var i = 0; i < 3; i++) \{\
            var tt = tamTruyenData[i];\
            var ttIdx = thienTuong[tt.branch];\
            tt.branchName = DIA_CHI[tt.branch];\
            tt.generalIdx = ttIdx !== undefined ? ttIdx : -1;\
            tt.generalName = ttIdx !== undefined ? THIEN_TUONG[ttIdx].name : '';\
            tt.lucThan = getLucThan(dayStemEl, CHI_ELEMENT[tt.branch]);\
            tt.lucThanName = LUC_THAN_NAMES[tt.lucThan] || '';\
            tt.truongSinh = getTruongSinh(dayCC.can, tt.branch);\
            tt.truongSinhName = TRUONG_SINH_NAMES[tt.truongSinh] || '';\
        \}\
\
        return \{\
            // Input info\
            viewDate: viewDate,\
            viewHour: viewHour,\
            viewMinute: viewMinute,\
            birthInfo: birthDate ? \{\
                date: birthDate,\
                hour: birthHour || 0,\
                minute: birthMinute || 0,\
                gender: gender || 'Nam'\
            \} : null,\
\
            // Four Pillars\
            fourPillars: \{\
                year: yearCC, month: monthCC, day: dayCC, hour: hourCC\
            \},\
            birthPillars: birthPillars,\
\
            // Solar term\
            solarTerm: solarTerm,\
            yuan: yuan,\
            yuanName: yuan || '', // String directly returned by getYuan\
\
            // Nguy\'e1\'bb\'87t T\'c6\'b0\'e1\'bb\'9bng\
            nguyetTuong: nguyetTuong,\
\
            // Thi\uc0\u258 \'aan \'c4\u144 \'e1\'bb\'8ba B\u258 \'a0n\
            thienBan: thienBan,\
            palaces: palaces,\
\
            // Qu\uc0\u258 \'bd Nh\u258 \'a2n\
            quyNhanBranch: quyNhanBranch,\
            isDaytime: isDaytime(hourChi),\
\
            // Thi\uc0\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng map\
            thienTuong: thienTuong,\
\
            // T\'e1\'bb\'a9 Kh\uc0\u258 \'b3a\
            tuKhoa: tuKhoa,\
\
            // Tam Truy\'e1\'bb\uc0\u129 n\
            tamTruyen: tamTruyenData,\
\
            // Kh\uc0\u258 \'b4ng Vong\
            kongWang: \{\
                year: kvYear, month: kvMonth, day: kvDay, hour: kvHour\
            \},\
            birthKW: birthKW,\
            birthKongWang: birthKW,\
            _hasBirth: !!birthDate,\
            _gender: gender || 'Nam',\
\
            // Day info\
            dayCan: dayCC.can,\
            dayChi: dayCC.chi\
        \};\
    \}\
\
    function getYuan(can, chi) \{\
        // Nguy\uc0\u258 \'aan (Th\'c6\'b0\'e1\'bb\'a3ng/Trung/H\'e1\'ba\'a1) \'c4\'91\'c6\'b0\'e1\'bb\'a3c t\u258 \'adnh theo Ph\u258 \'b9 \'c4\u144 \'e1\'ba\'a7u (ng\u258 \'a0y Gi\u258 \'a1p ho\'e1\'ba\'b7c K\'e1\'bb\'b7 g\'e1\'ba\'a7n nh\'e1\'ba\'a5t)\
        // M\'e1\'bb\'97i Nguy\uc0\u258 \'aan k\u258 \'a9o d\u258 \'a0i 5 ng\u258 \'a0y.\
        var offset = can % 5;\
        var phuDauChi = (chi - offset + 12) % 12;\
        \
        // T\uc0\u258 \'bd(0), M\u258 \'a3o(3), Ng\'e1\'bb\u141 (6), D\'e1\'ba\'adu(9) -> % 3 = 0 -> Th\'c6\'b0\'e1\'bb\'a3ng Nguy\u258 \'aan\
        // S\'e1\'bb\'adu(1), Th\uc0\u258 \'acn(4), M\u258 \'b9i(7), Tu\'e1\'ba\'a5t(10) -> % 3 = 1 -> H\'e1\'ba\'a1 Nguy\u258 \'aan\
        // D\'e1\'ba\'a7n(2), T\'e1\'bb\'b5(5), Th\uc0\u258 \'a2n(8), H\'e1\'bb\'a3i(11) -> % 3 = 2 -> Trung Nguy\u258 \'aan\
        var mod = phuDauChi % 3;\
        if (mod === 0) return 'Th\'c6\'b0\'e1\'bb\'a3ng Nguy\uc0\u258 \'aan';\
        if (mod === 1) return 'H\'e1\'ba\'a1 Nguy\uc0\u258 \'aan';\
        if (mod === 2) return 'Trung Nguy\uc0\u258 \'aan';\
        return 'Th\'c6\'b0\'e1\'bb\'a3ng Nguy\uc0\u258 \'aan';\
    \}\
\
    // ============================================================\
    //  UTILITY & EXPORTS\
    // ============================================================\
\
    function formatCanChi(cc) \{\
        return THIEN_CAN[cc.can] + ' ' + DIA_CHI[cc.chi];\
    \}\
\
    function getCanName(idx) \{ return THIEN_CAN[idx]; \}\
    function getChiName(idx) \{ return DIA_CHI[idx]; \}\
\
    // ============================================================\
    //  RAW TEXT FOR AI\
    // ============================================================\
\
    function generateRawText(result) \{\
        var lines = [];\
        lines.push('H\uc0\u258 \'a3y \'c4\'91\u258 \'b3ng vai m\'e1\'bb\'99t chuy\u258 \'aan gia L\'e1\'bb\'a5c Nh\u258 \'a2m \'c4\u144 \'e1\'ba\'a1i \'c4\u144 \'e1\'bb\'99n (\'e5\'a4\'a7\'e5\'85\'ad\'e5\'a3\'ac) v\u258 \'a0 lu\'e1\'ba\'adn gi\'e1\'ba\'a3i b\u258 \'a0n qu\'e1\'ba\'bb n\u258 \'a0y.');\
        if (result._question) \{\
            lines.push('');\
            lines.push('**C\uc0\u258 \'a2u h\'e1\'bb\u143 i c\'e1\'bb\'a7a ng\'c6\'b0\'e1\'bb\u157 i xem:** ' + result._question);\
        \}\
        lines.push('');\
        lines.push('**Th\uc0\u258 \'b4ng tin th\'e1\'bb\u157 i gian l\'e1\'ba\'adp qu\'e1\'ba\'bb:**');\
        lines.push('\'e2\'80\'93 N\'c4\'83m: ' + formatCanChi(result.fourPillars.year));\
        lines.push('\'e2\'80\'93 Th\uc0\u258 \'a1ng: ' + formatCanChi(result.fourPillars.month));\
        lines.push('\'e2\'80\'93 Ng\uc0\u258 \'a0y: ' + formatCanChi(result.fourPillars.day));\
        lines.push('\'e2\'80\'93 Gi\'e1\'bb\uc0\u157 : ' + formatCanChi(result.fourPillars.hour));\
        lines.push('\'e2\'80\'93 Ti\'e1\'ba\'bft kh\uc0\u258 \'ad: ' + result.solarTerm.name);\
        lines.push('\'e2\'80\'93 Nguy\uc0\u258 \'aan: ' + result.yuanName);\
        lines.push('\'e2\'80\'93 Nguy\'e1\'bb\'87t T\'c6\'b0\'e1\'bb\'9bng: ' + DIA_CHI[result.nguyetTuong.branch] + ' (' + result.nguyetTuong.name + ')');\
        lines.push('\'e2\'80\'93 Qu\uc0\u258 \'bd Nh\u258 \'a2n: ' + DIA_CHI[result.quyNhanBranch] + ' (' + (result.isDaytime ? 'Ng\u258 \'a0y' : '\'c4\u144 \u258 \'aam') + ' qu\u258 \'bd)');\
\
        // Kh\uc0\u258 \'b4ng vong (qu\'e1\'ba\'bb)\
        var kvParts = [];\
        kvParts.push(DIA_CHI[result.kongWang.day[0]] + ' ' + DIA_CHI[result.kongWang.day[1]]);\
        lines.push('\'e2\'80\'93 Kh\uc0\u258 \'b4ng Vong (Ng\u258 \'a0y): ' + kvParts.join(', '));\
\
        // Sinh th\'e1\'ba\'a7n (birth data) \'e2\'80\'94 if provided\
        if (result._hasBirth && result.birthPillars) \{\
            lines.push('');\
            lines.push('**Th\uc0\u258 \'b4ng tin ng\'c6\'b0\'e1\'bb\u157 i h\'e1\'bb\u143 i (Sinh Th\'e1\'ba\'a7n):**');\
            lines.push('\'e2\'80\'93 B\uc0\u258 \'a1t T\'e1\'bb\'b1: ' +\
                formatCanChi(result.birthPillars.year) + ', ' +\
                formatCanChi(result.birthPillars.month) + ', ' +\
                formatCanChi(result.birthPillars.day) + ', ' +\
                formatCanChi(result.birthPillars.hour));\
            lines.push('\'e2\'80\'93 Gi\'e1\'bb\'9bi t\uc0\u258 \'adnh: ' + (result._gender || 'Nam'));\
            if (result.birthKongWang) \{\
                var bkv = result.birthKongWang;\
                lines.push('\'e2\'80\'93 Kh\uc0\u258 \'b4ng Vong (Sinh Th\'e1\'ba\'a7n):');\
                lines.push('  + N\'c4\'83m sinh: ' + DIA_CHI[bkv.year[0]] + ' ' + DIA_CHI[bkv.year[1]]);\
                lines.push('  + Ng\uc0\u258 \'a0y sinh: ' + DIA_CHI[bkv.day[0]] + ' ' + DIA_CHI[bkv.day[1]]);\
            \}\
            // M\'e1\'bb\'87nh (year branch) for reference\
            lines.push('\'e2\'80\'93 M\'e1\'bb\'87nh (n\'c4\'83m sinh): ' + DIA_CHI[result.birthPillars.year.chi]);\
            // Nh\'e1\'ba\'adt Can sinh \'e2\'86\'92 Ng\'c5\'a9 H\uc0\u258 \'a0nh of person\
            lines.push('\'e2\'80\'93 Nh\'e1\'ba\'adt Ch\'e1\'bb\'a7 (ng\uc0\u258 \'a0y sinh): ' + THIEN_CAN[result.birthPillars.day.can] +\
                ' (' + NGU_HANH[CAN_ELEMENT[result.birthPillars.day.can]] + ')');\
        \}\
        lines.push('');\
\
        // T\'e1\'bb\'a9 Kh\uc0\u258 \'b3a\
        lines.push('**T\'e1\'bb\'a9 Kh\uc0\u258 \'b3a:**');\
        for (var i = 0; i < 4; i++) \{\
            var tk = result.tuKhoa[i];\
            lines.push('\'e2\'80\'93 Kh\uc0\u258 \'b3a ' + tk.label + ': ' + DIA_CHI[tk.top] + '/' + DIA_CHI[tk.bottom] +\
                ' [' + tk.generalName + '] [' + tk.lucThanName + ']');\
        \}\
        lines.push('');\
\
        // Tam Truy\'e1\'bb\uc0\u129 n\
        lines.push('**Tam Truy\'e1\'bb\uc0\u129 n:**');\
        for (var i = 0; i < 3; i++) \{\
            var tt = result.tamTruyen[i];\
            lines.push('\'e2\'80\'93 ' + tt.label + ' Truy\'e1\'bb\uc0\u129 n: ' + tt.branchName +\
                ' [' + tt.generalName + '] [' + tt.lucThanName + ']');\
        \}\
        lines.push('');\
\
        // Thi\uc0\u258 \'aan \'c4\u144 \'e1\'bb\'8ba B\u258 \'a0n (12 cung) \'e2\'80\'94 updated with Lo\'e1\'ba\'a1i Th\'e1\'ba\'a7n + Th\'e1\'ba\'a7n S\u258 \'a1t\
        lines.push('**Thi\uc0\u258 \'aan \'c4\u144 \'e1\'bb\'8ba B\u258 \'a0n (12 cung):**');\
        for (var p = 0; p < 12; p++) \{\
            var pal = result.palaces[p];\
            var thanSatStr = (pal.thanSat && pal.thanSat.length > 0) ? pal.thanSat.join(', ') : '';\
            lines.push('\'e2\'80\'93 ' + DIA_CHI[p] + ' (\'c4\uc0\u144 \'e1\'bb\'8ba) \'e2\'86\u144  ' + pal.thienBanName + ' (Thi\u258 \'aan): ' +\
                pal.generalName + ', ' + pal.loaiThanName + ', ' + thanSatStr);\
        \}\
\
        return lines.join('\\n');\
    \}\
\
    return \{\
        calculate: calculate,\
        formatCanChi: formatCanChi,\
        getCanName: getCanName,\
        getChiName: getChiName,\
        generateRawText: generateRawText,\
        THIEN_CAN: THIEN_CAN,\
        DIA_CHI: DIA_CHI,\
        NGU_HANH: NGU_HANH,\
        THIEN_TUONG: THIEN_TUONG,\
        NGUYET_TUONG_NAMES: NGUYET_TUONG_NAMES,\
        LUC_THAN_NAMES: LUC_THAN_NAMES,\
        LOAI_THAN_NAMES: LOAI_THAN_NAMES,\
        VONG_THAI_TUE: VONG_THAI_TUE,\
        TRUONG_SINH_NAMES: TRUONG_SINH_NAMES,\
        CHI_ELEMENT: CHI_ELEMENT,\
        CAN_ELEMENT: CAN_ELEMENT\
    \};\
\})();\
}