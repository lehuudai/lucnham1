                \} else \{\
                    if (isDayYang) \{\
                        soTruyen = thienBan[9];\
                        trungTruyen = thienBan[dayChi];\
                        matTruyen = thienBan[canLodge];\
                    \} else \{\
                        for (var p = 0; p < 12; p++) \{\
                            if (thienBan[p] === 9) \{ soTruyen = p; break; \}\
                        \}\
                        trungTruyen = thienBan[canLodge];\
                        matTruyen = thienBan[dayChi];\
                    \}\
                    return \{ so: soTruyen, trung: trungTruyen, mat: matTruyen \};\
