            html += '<td>' + LNDD_Engine.formatCanChi(fp.hour) + '</td></tr>';\
            // Kh\uc0\u258 \'b4ng Vong row\
            html += '<tr class="lndd-tk-kv"><td>' + LNDD_Engine.getChiName(r.kongWang.year[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.year[1]) + '</td>';\
            html += '<td>' + LNDD_Engine.getChiName(r.kongWang.month[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.month[1]) + '</td>';\
            html += '<td>' + LNDD_Engine.getChiName(r.kongWang.day[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.day[1]) + '</td>';\
            html += '<td>' + LNDD_Engine.getChiName(r.kongWang.hour[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.hour[1]) + '</td></tr>';\
            html += '</table>';\
        \}\
        else if (cellId === 'c2') \{\
            // Nguy\'e1\'bb\'87t T\'c6\'b0\'e1\'bb\'9bng + Can Chi info\
            html += '<div class="lndd-center-title">NGUY\'e1\'bb\'86T T\'c6\'af\'e1\'bb\uc0\u154 NG</div>';\
            html += '<div class="lndd-nt-big">' + LNDD_Engine.getChiName(r.nguyetTuong.branch) + '</div>';\
            html += '<div class="lndd-nt-name">' + r.nguyetTuong.name + '</div>';\
            html += '<table class="lndd-can-chi-table">';\
