        // 1. Ph\'e1\'bb\'a5c Ng\uc0\u258 \'a2m (\'e4\'bc\u143 \'e5\u144 \'9f\'e8\'af\'be)\
        if (thienBan[0] === 0) \{\
            var k1TopEl = CHI_ELEMENT[canLodge];\
            if (doesOvercome(k1TopEl, dayStemEl) || doesOvercome(dayStemEl, k1TopEl)) \{\
                soTruyen = canLodge;\
            \} else \{\
                soTruyen = isDayYang ? canLodge : dayChi;\
            \}\
            var getHinh = function(b) \{\
                var h = [3, 10, 5, 0, 4, 8, 6, 1, 2, 9, 7, 11];\
                return h[b];\
            \};\
            trungTruyen = getHinh(soTruyen);\
            if (trungTruyen === soTruyen) \{\
                matTruyen = (trungTruyen + 6) % 12;\
            \} else \{\
                matTruyen = getHinh(trungTruyen);\
                if (matTruyen === trungTruyen || matTruyen === soTruyen) \{\
                    matTruyen = (trungTruyen + 6) % 12;\
                \}\
            \}\
            return \{ so: soTruyen, trung: trungTruyen, mat: matTruyen \};\
        \}\
\
        // 2. Ph\'e1\'ba\'a3n Ng\uc0\u258 \'a2m (\'e8\'bf\'94\'e5\u144 \'9f\'e8\'af\'be)\
        if (thienBan[0] === 6) \{\
            var hasOvercome = false;\
            for (var i = 0; i < 4; i++) \{\
                var topEl = CHI_ELEMENT[tuKhoa[i].top];\
                var botEl = (i === 0) ? dayStemEl : CHI_ELEMENT[tuKhoa[i].bottom];\
                if (doesOvercome(topEl, botEl) || doesOvercome(botEl, topEl)) hasOvercome = true;\
            \}\
            if (!hasOvercome) \{\
                var tamHopKey = [2, 1, 0, 3, 2, 1, 0, 3, 2, 1, 0, 3];\
                var maPositions = [8, 11, 2, 5];\
                soTruyen = maPositions[tamHopKey[dayChi]];\
                trungTruyen = dayChi;\
                matTruyen = canLodge;\
                return \{ so: soTruyen, trung: trungTruyen, mat: matTruyen \};\
            \}\
            // N\'e1\'ba\'bfu c\uc0\u258 \'b3 kh\'e1\'ba\'afc, s\'e1\'ba\'bd l\'e1\'bb\u141 t xu\'e1\'bb\'91ng x\'e1\'bb\'ad l\u258 \'bd T\'e1\'ba\'b7c Kh\'e1\'ba\'afc/T\'e1\'bb\'b7 D\'e1\'bb\'a5ng b\u258 \'aan d\'c6\'b0\'e1\'bb\'9bi\
        \}\
\
        // 3. B\uc0\u258 \'a1t Chuy\u258 \'aan (\'e5\'85\'ab\'e4\'b8\'93\'e8\'af\'be)\
        if (canLodge === dayChi && courseCount <= 2) \{\
            var k1TopEl = CHI_ELEMENT[tuKhoa[0].top];\
            var k1HasKe = doesOvercome(k1TopEl, dayStemEl) || doesOvercome(dayStemEl, k1TopEl);\
            var k2TopEl = CHI_ELEMENT[tuKhoa[1].top];\
            var k2BotEl = CHI_ELEMENT[tuKhoa[1].bottom];\
            var k2HasKe = doesOvercome(k2TopEl, k2BotEl) || doesOvercome(k2BotEl, k2TopEl);\
\
            if (!k1HasKe && !k2HasKe) \{\
                var tamHopKey = [2, 1, 0, 3, 2, 1, 0, 3, 2, 1, 0, 3];\
                var maPositions = [8, 11, 2, 5];\
                soTruyen = maPositions[tamHopKey[dayChi]];\
            \} else \{\
                if (k1HasKe && !k2HasKe) soTruyen = tuKhoa[0].top;\
                else if (!k1HasKe && k2HasKe) soTruyen = tuKhoa[1].top;\
                else \{\
                    var isB1Yang = (tuKhoa[0].top % 2 === 0);\
                    soTruyen = (isDayYang === isB1Yang) ? tuKhoa[0].top : tuKhoa[1].top;\
                \}\
            \}\
            trungTruyen = thienBan[soTruyen];\
            matTruyen = thienBan[trungTruyen];\
            return \{ so: soTruyen, trung: trungTruyen, mat: matTruyen \};\
        \}\
\
        // \'e2\'94\'80\'e2\'94\'80 T\'e1\'ba\'b7c Kh\'e1\'ba\'afc (\'e8\'b4\'bc\'e5\'85\'8b) \'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\'e2\'94\'80\
        var shangKeXia = [];\
        var xiaKeShang = [];\
        for (var i = 0; i < 4; i++) \{\
            var topEl = CHI_ELEMENT[tuKhoa[i].top];\
            var botEl = (i === 0) ? dayStemEl : CHI_ELEMENT[tuKhoa[i].bottom];\
            if (doesOvercome(topEl, botEl)) shangKeXia.push(\{ courseIdx: i, branch: tuKhoa[i].top, type: 'shangke' \});\
            if (doesOvercome(botEl, topEl)) xiaKeShang.push(\{ courseIdx: i, branch: tuKhoa[i].top, type: 'xiake' \});\
        \}\
        shangKeXia = getUniqueCandidates(shangKeXia);\
        xiaKeShang = getUniqueCandidates(xiaKeShang);\
\
        var candidates = (shangKeXia.length > 0) ? shangKeXia : xiaKeShang;\
\
        if (candidates.length === 1) \{\
            soTruyen = candidates[0].branch;\
