\
    // ============================================================\
    //  LO\'e1\'ba\'a0I TH\'e1\'ba\'a6N (\'e5\uc0\u141 \u129 \'e4\'ba\'8c\'e9\'a1\u158 \'e7\'a5\u158  \'e2\'80\'94 matching PTTL)\
    // ============================================================\
    // Placed on \'c4\uc0\u144 \'e1\'bb\'8ba B\u258 \'a0n: "Ki\'e1\'ba\'bfn" starts at dayChi position, then proceeds in order.\
    var LOAI_THAN_NAMES = ['Ki\'e1\'ba\'bfn', 'L\'e1\'bb\'a3i', 'Ph\uc0\u258 \'bac', 'Hung', 'C\u258 \'b4', 'Ph\'e1\'ba\'bf',\
                           'H\'c6\'b0u', 'T\'e1\'bb\'ad', 'T\uc0\u258 \'b9', 'M\'e1\'bb\'99t', 'Thai', 'V\'c6\'b0\'e1\'bb\'a3ng'];\
\
    function getLoaiThan(dayChi, diBan) \{\
        return (diBan - dayChi + 12) % 12;\
    \}\
\
    // ============================================================\
    //  TH\'e1\'ba\'a6N S\uc0\u258 \u129 T \'e2\'80\'94 V\u258 \'b2ng Th\u258 \'a1i Tu\'e1\'ba\'bf (\'e5\'a4\'aa\'e6\'ad\'b2\'e5\'91\'a8\'e6\'9c\'9f) + b\'e1\'bb\'95 sung\
    //  Verified against PTTL (phongthuyThangLong.vn)\
    // ============================================================\
    // 12 sao ch\uc0\u258 \'adnh \'c4\'91\'e1\'ba\'b7t theo Thi\u258 \'aan B\u258 \'a0n (TB), offset t\'e1\'bb\'ab yearChi:\
    var VONG_THAI_TUE = [\
        'Th\uc0\u258 \'a1i Tu\'e1\'ba\'bf',    // +0\
        'Th\uc0\u258 \'a1i D\'c6\'b0\'c6\'a1ng',  // +1\
        'T\uc0\u258 \'a0ng M\u258 \'b4n',    // +2\
        'Th\uc0\u258 \'a1i \u258 \'82m',     // +3 (s\u258 \'a1t, kh\u258 \'a1c Thi\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng Th\u258 \'a1i \u258 \'82m)\
        'Quan Ph\'e1\'bb\'a7',    // +4\
        'T\'e1\'bb\'ad Ph\'e1\'bb\'a7',      // +5\
        'Tu\'e1\'ba\'bf Ph\uc0\u258 \'a1',     // +6\
        'Long \'c4\uc0\u144 \'e1\'bb\'a9c',    // +7\
        'B\'e1\'ba\'a1ch H\'e1\'bb\'95',    // +8 (s\uc0\u258 \'a1t, kh\u258 \'a1c Thi\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng B\'e1\'ba\'a1ch H\'e1\'bb\'95)\
        'Ph\uc0\u258 \'bac \'c4\u144 \'e1\'bb\'a9c',    // +9\
        '\'c4\uc0\u144 i\'e1\'bb\u129 u Kh\u258 \'a1ch',  // +10\
