    /** Find the most recent Trung Kh\uc0\u258 \'ad and return the Nguy\'e1\'bb\'87t T\'c6\'b0\'e1\'bb\'9bng branch */\
    function getNguyetTuong(year, month, day, hour, minute) \{\
        var jd = KMDG_Solar.dateToJD(year, month, day, hour || 0, minute || 0);\
\
        // Collect all solar terms for adjacent years\
        var allTerms = [];\
        for (var yr = year - 1; yr <= year + 1; yr++) \{\
