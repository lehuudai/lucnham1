            html += '<tr><td class="lndd-val">' + LNDD_Engine.getCanName(r.dayCan) + '</td>';\
            html += '<td class="lndd-val">' + LNDD_Engine.getChiName(r.dayChi) + '</td></tr>';\
            html += '</table>';\
        \}\
        else if (cellId === 'c3') \{\
            // T\'e1\'bb\'a9 Kh\uc0\u258 \'b3a\
            html += '<div class="lndd-center-title">T\'e1\'bb\'a8 KH\uc0\u258 \'93A</div>';\
            html += '<table class="lndd-tukhoa-table">';\
            html += '<tr><th>NH\'e1\'ba\'a4T</th><th>NH\'e1\'bb\uc0\u138 </th><th>TAM</th><th>T\'e1\'bb\'a8</th></tr>';\
            // Thi\uc0\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng row\
            html += '<tr class="lndd-tt-row">';\
            for (var i = 0; i < 4; i++) html += '<td class="lndd-general-name">' + r.tuKhoa[i].generalName + '</td>';\
            html += '</tr>';\
            // Top branch row\
            html += '<tr>';\
            for (var i = 0; i < 4; i++) html += '<td class="lndd-tk-top">' + LNDD_Engine.getChiName(r.tuKhoa[i].top) + '</td>';\
            html += '</tr>';\
            // Bottom branch row\
            html += '<tr>';\
            for (var i = 0; i < 4; i++) \{\
                var botText = LNDD_Engine.getChiName(r.tuKhoa[i].bottom);\
                if (i === 0) botText = LNDD_Engine.getCanName(r.dayCan);\
                html += '<td class="lndd-tk-bot">' + botText + '</td>';\
            \}\
            html += '</tr>';\
            html += '</table>';\
        \}\
        else if (cellId === 'c4') \{\
            // Tam Truy\'e1\'bb\uc0\u129 n\
            html += '<div class="lndd-center-title">TAM TRUY\'e1\'bb\'80N</div>';\
            html += '<table class="lndd-tamtruyen-table">';\
            html += '<tr><th></th><th>Chi</th><th>L\'e1\'bb\'a5c Th\uc0\u258 \'a2n</th><th>Thi\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng</th></tr>';\
            for (var i = 0; i < 3; i++) \{\
                var tt = r.tamTruyen[i];\
                html += '<tr>';\
                html += '<td class="lndd-tt-label">' + tt.label + '</td>';\
                html += '<td class="lndd-tt-branch">' + tt.branchName + '</td>';\
                html += '<td class="lndd-tt-lt">' + tt.lucThanName + '</td>';\
                html += '<td class="lndd-tt-gen">' + tt.generalName + '</td>';\
                html += '</tr>';\
            \}\
            html += '</table>';\
        \}\
\
        html += '</div>';\
        return html;\
    \}\
\
    // ============================================================\
