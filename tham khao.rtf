     * Rule: \'e8\'b4\'b5\'e4\'ba\'ba\'e5\'b1\'85\'e9\'98\'b3\'e5\'88\'99\'e9\'80\'86, \'e5\'b1\'85\'e9\'98\'b4\'e5\'88\'99\'e9\'a1\'ba\
     *   - QN branch is D\'c6\'b0\'c6\'a1ng (even: 0,2,4,6,8,10) \'e2\'86\'92 backward (\'e9\'80\'86\'e8\'a1\'8c)\
     *   - QN branch is \uc0\u258 \'82m   (odd: 1,3,5,7,9,11) \'e2\'86\'92 forward  (\'e9\'a0\'86\'e8\'a1\'8c)\
     * Returns: tuong[branch] = general index (0-11)\
     */\
    function buildThienTuong(quyNhanBranch, thienBan) \{\
        var tuong = [];\
        var diBanPos = 0;\
        for (var i = 0; i < 12; i++) \{\
            if (thienBan[i] === quyNhanBranch) \{\
                diBanPos = i; break;\
            \}\
        \}\
        // Qu\uc0\u258 \'bd Nh\u258 \'a2n c\'c6\'b0 H\'e1\'bb\'a3i, T\u258 \'bd, S\'e1\'bb\'adu, D\'e1\'ba\'a7n, M\u258 \'a3o, Th\u258 \'acn (11, 0, 1, 2, 3, 4) -> Thu\'e1\'ba\'adn\
        var isForward = (diBanPos === 11 || (diBanPos >= 0 && diBanPos <= 4));\
        for (var i = 0; i < 12; i++) \{\
            var pos;\
            if (!isForward) \{\
                // Backward (\'e9\'80\'86): QN at branch, next at branch-1, etc.\
                pos = ((quyNhanBranch - i) % 12 + 12) % 12;\
            \} else \{\
                // Forward (\'e9\'a0\'86): QN at branch, next at branch+1, etc.\
                pos = (quyNhanBranch + i) % 12;\
            \}\
            tuong[pos] = i; // index into THIEN_TUONG array\
        \}\
        return tuong; // tuong[branch] = generalIndex\
    \}\
\
    // ============================================================\
    //  L\'e1\'bb\'a4C TH\uc0\u258 \'82N (Six Relations)\
    // ============================================================\
\
    // Ng\'c5\'a9 H\uc0\u258 \'a0nh t\'c6\'b0\'c6\'a1ng sinh: M\'e1\'bb\'99c(0)\'e2\'86\'92H\'e1\'bb\u143 a(1)\'e2\'86\'92Th\'e1\'bb\'95(2)\'e2\'86\'92Kim(3)\'e2\'86\'92Th\'e1\'bb\'a7y(4)\'e2\'86\'92M\'e1\'bb\'99c(0)\
    // generates(a) = (a+1)%5,  overcomes(a) = (a+2)%5\
    function getLucThan(dayStemElement, branchElement) \{\
        if (dayStemElement === branchElement) return 0; // Huynh \'c4\uc0\u144 \'e1\'bb\'87 (same element)\
        if ((dayStemElement + 1) % 5 === branchElement) return 1; // T\'e1\'bb\'ad T\uc0\u258 \'b4n (I generate it)\
        if ((dayStemElement + 2) % 5 === branchElement) return 2; // Th\uc0\u258 \'aa T\u258 \'a0i (I overcome it)\
        if ((branchElement + 2) % 5 === dayStemElement) return 3; // Quan Qu\'e1\'bb\'b7 (it overcomes me)\
        if ((branchElement + 1) % 5 === dayStemElement) return 4; // Ph\'e1\'bb\'a5 M\'e1\'ba\'abu (it generates me)\
        return 0; // fallback\
    \}\
\
    // ============================================================\
    //  TR\'c6\'af\'e1\'bb\'9cNG SINH (12 Life Stages)\
    // ============================================================\
\
    function getTruongSinh(dayCan, branch) \{\
        var start = TRUONG_SINH_START[dayCan];\
        var isYang = (dayCan % 2 === 0);\
        var offset;\
        if (isYang) \{\
            offset = (branch - start + 12) % 12;\
        \} else \{\
            offset = (start - branch + 12) % 12;\
        \}\
        return offset; // index into TRUONG_SINH_NAMES\
    \}\
\
    // ============================================================\
    //  T\'e1\'bb\'a8 KH\uc0\u258 \'93A (Four Courses)\
