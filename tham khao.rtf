            // T\'e1\'bb\'b7 D\'e1\'bb\'a5ng (\'e6\'af\'94\'e7\'94\'a8)\
            var biYong = [];\
            for (var i = 0; i < candidates.length; i++) \{\
                if (isDayYang === (candidates[i].branch % 2 === 0)) biYong.push(candidates[i]);\
            \}\
            if (biYong.length === 1) \{\
                soTruyen = biYong[0].branch;\
            \} else \{\
                // Thi\'e1\'bb\'87p H\'e1\'ba\'a1i (\'e6\'b6\'89\'e5\'ae\'b3)\
                var cands = (biYong.length > 1) ? biYong : candidates;\
                var maxDepth = -1;\
                var selected = cands[0].branch;\
                for (var i = 0; i < cands.length; i++) \{\
                    var branch = cands[i].branch;\
                    var type = cands[i].type;\
                    var earthPos = -1;\
                    for (var p = 0; p < 12; p++) \{\
                        if (thienBan[p] === branch) \{ earthPos = p; break; \}\
                    \}\
                    var depth = 0;\
                    var currentPos = earthPos;\
                    var homePos = branch;\
                    var targetEl = CHI_ELEMENT[branch];\
                    for (var step = 0; step < 12; step++) \{\
                        var earthEl = CHI_ELEMENT[currentPos];\
                        if (type === 'shangke' && doesOvercome(targetEl, earthEl)) depth++;\
                        if (type === 'xiake' && doesOvercome(earthEl, targetEl)) depth++;\
                        if (currentPos === homePos) break;\
                        currentPos = (currentPos + 1) % 12;\
                    \}\
                    var weight = 1;\
                    if ([2, 8, 5, 11].indexOf(earthPos) !== -1) weight = 3;\
                    else if ([0, 6, 3, 9].indexOf(earthPos) !== -1) weight = 2;\
                    var totalScore = depth * 10 + weight;\
                    if (totalScore > maxDepth) \{ maxDepth = totalScore; selected = branch; \}\
                \}\
                soTruyen = selected;\
            \}\
        \} else \{\
            // Dao Kh\'e1\'ba\'afc (\'e9\uc0\u129 \'a5\'e5\'85\'8b)\
            var dayVSCourses = [];\
            for (var i = 1; i < 4; i++) \{\
                var topEl = CHI_ELEMENT[tuKhoa[i].top];\
                if (doesOvercome(topEl, dayStemEl)) dayVSCourses.push(\{ branch: tuKhoa[i].top \});\
            \}\
            dayVSCourses = getUniqueCandidates(dayVSCourses);\
            if (dayVSCourses.length === 0) \{\
                for (var i = 1; i < 4; i++) \{\
                    var topEl = CHI_ELEMENT[tuKhoa[i].top];\
                    if (doesOvercome(dayStemEl, topEl)) dayVSCourses.push(\{ branch: tuKhoa[i].top \});\
                \}\
                dayVSCourses = getUniqueCandidates(dayVSCourses);\
            \}\
            \
            if (dayVSCourses.length === 1) \{\
                soTruyen = dayVSCourses[0].branch;\
            \} else if (dayVSCourses.length > 1) \{\
                var matched = [];\
                for (var i = 0; i < dayVSCourses.length; i++) \{\
                    if (isDayYang === (dayVSCourses[i].branch % 2 === 0)) matched.push(dayVSCourses[i]);\
                \}\
                soTruyen = (matched.length > 0) ? matched[0].branch : dayVSCourses[0].branch;\
            \} else \{\
                // Bi\'e1\'bb\'87t Tr\uc0\u258 \'a1ch (\'e5\'88\'ab\'e8\'b4\'a3) / M\u258 \'a3o Tinh (\'e6\'98\'b4\'e6\'98\'9f)\
                if (courseCount === 3) \{\
                    if (isDayYang) \{\
                        var canHop = (dayCan + 5) % 10;\
