    function doesOvercome(elA, elB) \{\
        return (elA + 2) % 5 === elB;\
    \}\
\
    function buildTamTruyen(tuKhoa, dayCan, thienBan) \{\
        var dayStemEl = CAN_ELEMENT[dayCan];\
        var dayChi = tuKhoa[2].bottom;\
        var canLodge = tuKhoa[0].bottom;\
        var isDayYang = (dayCan % 2 === 0);\
\
        function getUniqueCandidates(arr) \{\
            var res = [];\
            var seen = \{\};\
            for (var k = 0; k < arr.length; k++) \{\
                if (!seen[arr[k].branch]) \{\
                    seen[arr[k].branch] = true;\
                    res.push(arr[k]);\
                \}\
            \}\
            return res;\
        \}\
\
        var uniqueCourses = \{\};\
        for (var i = 0; i < 4; i++) \{\
            uniqueCourses[tuKhoa[i].top + '-' + tuKhoa[i].bottom] = true;\
