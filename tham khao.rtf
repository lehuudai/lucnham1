\
    function buildTuKhoa(dayCan, dayChi, thienBan) \{\
        var canLodge = CAN_KY_CUNG[dayCan];\
\
        // 1st Course: Bottom = canLodge, Top = thienBan[canLodge]\
        var k1_bot = canLodge;\
        var k1_top = thienBan[canLodge];\
\
        // 2nd Course: Bottom = k1_top, Top = thienBan[k1_top]\
        var k2_bot = k1_top;\
        var k2_top = thienBan[k1_top];\
\
        // 3rd Course: Bottom = dayChi, Top = thienBan[dayChi]\
        var k3_bot = dayChi;\
        var k3_top = thienBan[dayChi];\
\
        // 4th Course: Bottom = k3_top, Top = thienBan[k3_top]\
        var k4_bot = k3_top;\
        var k4_top = thienBan[k3_top];\
\
        return [\
            \{ top: k1_top, bottom: k1_bot, label: 'Nh\'e1\'ba\'a5t' \},\
            \{ top: k2_top, bottom: k2_bot, label: 'Nh\'e1\'bb\'8b' \},\
            \{ top: k3_top, bottom: k3_bot, label: 'Tam' \},\
            \{ top: k4_top, bottom: k4_bot, label: 'T\'e1\'bb\'a9' \}\
        ];\
