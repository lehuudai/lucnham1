        \}\
        var effectiveYear = year;\
        if (lapXuan && jd < lapXuan.jd) effectiveYear = year - 1;\
        var canIdx = (effectiveYear - 4) % 10;\
        if (canIdx < 0) canIdx += 10;\
        var chiIdx = (effectiveYear - 4) % 12;\
        if (chiIdx < 0) chiIdx += 12;\
        return \{ can: canIdx, chi: chiIdx, jiaZi: getJiaZiIndex(canIdx, chiIdx) \};\
    \}\
\
    function getMonthCanChi(yearCan, solarTermName) \{\
        var termToMonth = \{\
            'L\'e1\'ba\'adp Xu\uc0\u258 \'a2n':0,'V\'c5\'a9 Th\'e1\'bb\'a7y':0,'Kinh Ch\'e1\'ba\'adp':1,'Xu\u258 \'a2n Ph\u258 \'a2n':1,\
