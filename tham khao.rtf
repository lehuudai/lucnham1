(function()\{\
    'use strict';\
\
    // ============================================================\
    //  SET CURRENT TIME\
    // ============================================================\
    window.lnddSetNow = function() \{\
        var now = new Date();\
        document.getElementById('lndd-view-year').value = now.getFullYear();\
        document.getElementById('lndd-view-month').value = now.getMonth() + 1;\
        document.getElementById('lndd-view-day').value = now.getDate();\
        document.getElementById('lndd-view-hour').value = now.getHours();\
        document.getElementById('lndd-view-minute').value = now.getMinutes();\
        document.getElementById('lndd-view-second').value = now.getSeconds();\
    \};\
\
    // ============================================================\
    //  LAP QUE\
    // ============================================================\
    window.lnddLapQue = function() \{\
        // Gather view time\
        var vy = parseInt(document.getElementById('lndd-view-year').value) || 2026;\
        var vm = parseInt(document.getElementById('lndd-view-month').value) || 1;\
        var vd = parseInt(document.getElementById('lndd-view-day').value) || 1;\
        var vh = parseInt(document.getElementById('lndd-view-hour').value) || 0;\
        var vmin = parseInt(document.getElementById('lndd-view-minute').value) || 0;\
        var vsec = parseInt(document.getElementById('lndd-view-second').value) || 0;\
\
        var viewDate = new Date(vy, vm - 1, vd);\
\
        // Gather birth info\
        var name = (document.getElementById('lndd-name').value || '').trim() || 'Kh\uc0\u258 \'b4ng r\u258 \'b5';\
        var gender = document.getElementById('lndd-gender').value || 'Nam';\
        var byRaw = document.getElementById('lndd-birth-year').value;\
        var birthDate = null, bh = 0, bmin = 0;\
        var hasBirth = byRaw && byRaw.trim() !== '';\
        if (hasBirth) \{\
            var by = parseInt(byRaw) || 2000;\
            var bm = parseInt(document.getElementById('lndd-birth-month').value) || 1;\
            var bd = parseInt(document.getElementById('lndd-birth-day').value) || 1;\
            bh = parseInt(document.getElementById('lndd-birth-hour').value) || 0;\
            bmin = parseInt(document.getElementById('lndd-birth-minute').value) || 0;\
            birthDate = new Date(by, bm - 1, bd);\
        \}\
\
        // Calculate\
        var result = LNDD_Engine.calculate(viewDate, vh, vmin, birthDate, bh, bmin, gender);\
        result._name = name;\
        result._gender = gender;\
        result._viewSecond = vsec;\
        result._hasBirth = hasBirth;\
        result._question = (document.getElementById('lndd-question').value || '').trim();\
\
        // Render\
        var area = document.getElementById('lndd-result-area');\
        area.style.display = 'block';\
        area.innerHTML = renderResult(result);\
        area.scrollIntoView(\{ behavior: 'smooth', block: 'start' \});\
    \};\
\
    // ============================================================\
    //  RENDER RESULT\
    // ============================================================\
    function renderResult(r) \{\
        var html = '';\
        html += renderHeaderInfo(r);\
        html += renderMainGrid(r);\
        html += renderPhoneBar();\
        html += renderRawText(r);\
        return html;\
    \}\
\
    // ============================================================\
    //  HEADER INFO\
    // ============================================================\
    function renderHeaderInfo(r) \{\
        var fp = r.fourPillars;\
        var batTu = LNDD_Engine.formatCanChi(fp.year) + ', ' +\
                    LNDD_Engine.formatCanChi(fp.month) + ', ' +\
                    LNDD_Engine.formatCanChi(fp.day) + ', ' +\
                    LNDD_Engine.formatCanChi(fp.hour);\
\
        var kvAll = [];\
        kvAll.push(LNDD_Engine.getChiName(r.kongWang.year[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.year[1]));\
        kvAll.push(LNDD_Engine.getChiName(r.kongWang.month[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.month[1]));\
        kvAll.push(LNDD_Engine.getChiName(r.kongWang.day[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.day[1]));\
        kvAll.push(LNDD_Engine.getChiName(r.kongWang.hour[0]) + ' ' + LNDD_Engine.getChiName(r.kongWang.hour[1]));\
\
        var dd = String(r.viewDate.getDate()).padStart(2, '0');\
        var mm = String(r.viewDate.getMonth() + 1).padStart(2, '0');\
        var yyyy = r.viewDate.getFullYear();\
        var hh = String(r.viewHour).padStart(2, '0');\
        var mi = String(r.viewMinute).padStart(2, '0');\
        var ss = String(r._viewSecond || 0).padStart(2, '0');\
        var timeStr = hh + 'h' + mi + '\\'' + ss + '" \'e2\'80\'94 Ng\uc0\u258 \'a0y ' + dd + '/' + mm + '/' + yyyy;\
\
  // --- Render HTML ---\
    var html = '<div class="lndd-header-info"><div class="lndd-info-grid">';\
    \
    // Left column\
    html += '<div class="lndd-info-left">';\
    html += '<div class="lndd-info-row"><span class="lndd-info-label">H\'e1\'bb\uc0\u141  t\u258 \'aan:</span> <span class="lndd-highlight">' + r._name + '</span></div>';\
    html += '<div class="lndd-info-row"><span class="lndd-info-label">Gi\'e1\'bb\'9bi T\uc0\u258 \'adnh:</span> ' + (r._gender || 'Nam') + '</div>';\
    \
    if (r._hasBirth && r.birthPillars) \{\
        html += '<div class="lndd-info-row"><span class="lndd-info-label">B\uc0\u258 \'a1t T\'e1\'bb\'b1 (Sinh Th\'e1\'ba\'a7n):</span> <span class="lndd-highlight">';\
        html += LNDD_Engine.formatCanChi(r.birthPillars.year) + ', ';\
        html += LNDD_Engine.formatCanChi(r.birthPillars.month) + ', ';\
        html += LNDD_Engine.formatCanChi(r.birthPillars.day) + ', ';\
        html += LNDD_Engine.formatCanChi(r.birthPillars.hour);\
        html += '</span></div>';\
        html += '<div class="lndd-info-row"><span class="lndd-info-label">Kh\uc0\u258 \'b4ng Vong (Sinh Th\'e1\'ba\'a7n):</span> <span class="lndd-kv-text">';\
        html += LNDD_Engine.getChiName(r.birthKW.year[0]) + ' ' + LNDD_Engine.getChiName(r.birthKW.year[1]) + ', ';\
        html += LNDD_Engine.getChiName(r.birthKW.month[0]) + ' ' + LNDD_Engine.getChiName(r.birthKW.month[1]) + ', ';\
        html += LNDD_Engine.getChiName(r.birthKW.day[0]) + ' ' + LNDD_Engine.getChiName(r.birthKW.day[1]) + ', ';\
        html += LNDD_Engine.getChiName(r.birthKW.hour[0]) + ' ' + LNDD_Engine.getChiName(r.birthKW.hour[1]);\
        html += '</span></div>';\
    \} else \{\
        html += '<div class="lndd-info-row"><span class="lndd-info-label">B\uc0\u258 \'a1t T\'e1\'bb\'b1 (Sinh Th\'e1\'ba\'a7n):</span> <span style="color:#999;font-style:italic">Ch\'c6\'b0a nh\'e1\'ba\'adp ng\u258 \'a0y sinh</span></div>';\
    \}\
    html += '</div>';\
    \
    // Right column\
    html += '<div class="lndd-info-right">';\
    html += '<div class="lndd-time-display">' + timeStr + ' (D\'c6\'b0\'c6\'a1ng L\'e1\'bb\'8bch)</div>';\
    html += '<div class="lndd-info-row"><span class="lndd-info-label">Ti\'e1\'ba\'bft:</span> <span class="lndd-highlight">' + r.solarTerm.name + '</span>';\
    html += ' &nbsp; <span class="lndd-info-label">Nguy\uc0\u258 \'aan:</span> <span class="lndd-highlight">' + r.yuanName + '</span></div>';\
    html += '<div class="lndd-info-row"><span class="lndd-info-label">Nguy\'e1\'bb\'87t T\'c6\'b0\'e1\'bb\'9bng:</span> <span class="lndd-nt-value">' + LNDD_Engine.getChiName(r.nguyetTuong.branch) + ' \'e2\'80\'94 ' + r.nguyetTuong.name + '</span></div>';\
    html += '<div class="lndd-info-row"><span class="lndd-info-label">Qu\uc0\u258 \'bd Nh\u258 \'a2n:</span> ' + LNDD_Engine.getChiName(r.quyNhanBranch) + ' (' + (r.isDaytime ? 'Ng\u258 \'a0y qu\u258 \'bd' : '\'c4\u144 \u258 \'aam qu\u258 \'bd') + ')</div>';\
    html += '</div>';\
    \
    html += '</div></div>';\
        return html;\
    \}\
\
    // ============================================================\
    //  MAIN GRID (4\uc0\u258 \'974 Thi\u258 \'aan \'c4\u144 \'e1\'bb\'8ba B\u258 \'a0n + Center)\
    // ============================================================\
\
    // Grid layout:\
    // Row 0: T\'e1\'bb\'b5(5)  Ng\'e1\'bb\uc0\u141 (6)  M\u258 \'b9i(7)  Th\u258 \'a2n(8)\
    // Row 1: Th\uc0\u258 \'acn(4)  [CENTER]        D\'e1\'ba\'adu(9)\
    // Row 2: M\uc0\u258 \'a3o(3)   [CENTER]        Tu\'e1\'ba\'a5t(10)\
    // Row 3: D\'e1\'ba\'a7n(2)  S\'e1\'bb\'adu(1) T\uc0\u258 \'bd(0)   H\'e1\'bb\'a3i(11)\
\
    var GRID_LAYOUT = [\
        [5,   6,    7,    8],\
        [4,   'c1', 'c2', 9],\
        [3,   'c3', 'c4', 10],\
        [2,   1,    0,    11]\
    ];\
\
    function renderMainGrid(r) \{\
        var html = '<div class="lndd-main-grid-wrapper">';\
\
        // Direction labels \'e2\'80\'94 top\
        html += '<div class="lndd-dir-top">';\
        html += '<span></span><span>T\'e1\'bb\'b5</span><span>Ng\'e1\'bb\uc0\u141 </span><span>M\u258 \'b9i</span><span></span>';\
        html += '</div>';\
\
        html += '<div class="lndd-grid-container">';\
        // Direction labels \'e2\'80\'94 left\
        html += '<div class="lndd-dir-left">';\
        html += '<span>Th\uc0\u258 \'acn</span><span>M\u258 \'a3o</span><span>D\'e1\'ba\'a7n</span>';\
        html += '</div>';\
\
        // The 4\uc0\u258 \'974 grid\
        html += '<div class="lndd-grid-4x4">';\
        for (var row = 0; row < 4; row++) \{\
            for (var col = 0; col < 4; col++) \{\
                var cell = GRID_LAYOUT[row][col];\
                if (typeof cell === 'number') \{\
                    html += renderPalaceCell(r, cell);\
                \} else \{\
                    html += renderCenterCell(r, cell);\
                \}\
            \}\
        \}\
        html += '</div>';\
\
        // Direction labels \'e2\'80\'94 right\
        html += '<div class="lndd-dir-right">';\
        html += '<span>Th\uc0\u258 \'a2n</span><span>D\'e1\'ba\'adu</span><span>Tu\'e1\'ba\'a5t</span>';\
        html += '</div>';\
\
        html += '</div>';\
\
        // Direction labels \'e2\'80\'94 bottom\
        html += '<div class="lndd-dir-bottom">';\
        html += '<span></span><span>S\'e1\'bb\'adu</span><span>T\uc0\u258 \'bd</span><span>H\'e1\'bb\'a3i</span><span></span>';\
        html += '</div>';\
\
        html += '</div>';\
        return html;\
    \}\
\
    // ============================================================\
    //  PALACE CELL (12 border cells)\
    // ============================================================\
\
    // Color map for elements\
    var ELEMENT_COLORS = \{\
        0: '#2e7d32', // M\'e1\'bb\'99c \'e2\'80\'94 green\
        1: '#c62828', // H\'e1\'bb\uc0\u143 a \'e2\'80\'94 red\
        2: '#795548', // Th\'e1\'bb\'95 \'e2\'80\'94 brown\
        3: '#ef6c00', // Kim \'e2\'80\'94 orange/gold\
        4: '#1565c0'  // Th\'e1\'bb\'a7y \'e2\'80\'94 blue\
    \};\
\
    function renderPalaceCell(r, diBanIdx) \{\
        var pal = r.palaces[diBanIdx];\
        var tbEl = LNDD_Engine.CHI_ELEMENT[pal.thienBan];\
        var tbColor = ELEMENT_COLORS[tbEl] || '#333';\
        var isKV = isKongWang(r, diBanIdx);\
        var isTamTruyen = isTamTruyenPalace(r, diBanIdx);\
        var kvClass = isKV ? ' lndd-cell-kv' : '';\
        var ttClass = isTamTruyen ? ' lndd-cell-tt' : '';\
\
        var html = '<div class="lndd-palace' + kvClass + ttClass + '">';\
\
        // Top line: \'c4\uc0\u144 \'e1\'bb\'8ba B\u258 \'a0n label + Thi\u258 \'aan B\u258 \'a0n branch\
        html += '<div class="lndd-p-header">';\
        html += '<span class="lndd-p-diban">' + LNDD_Engine.getChiName(diBanIdx) + '</span>';\
        html += '<span class="lndd-p-thienban" style="color:' + tbColor + '">' + pal.thienBanName + '</span>';\
        html += '</div>';\
\
        // Thi\uc0\u258 \'aan T\'c6\'b0\'e1\'bb\'9bng\
        html += '<div class="lndd-p-general">' + pal.generalName + '</div>';\
\
        // Nguy\'e1\'bb\'87t T\'c6\'b0\'e1\'bb\'9bng name (of Thi\uc0\u258 \'aan B\u258 \'a0n branch)\
        html += '<div class="lndd-p-nt">' + LNDD_Engine.NGUYET_TUONG_NAMES[pal.thienBan] + '</div>';\
\
        // Lo\'e1\'ba\'a1i Th\'e1\'ba\'a7n (line 3 \'e2\'80\'94 matching PTTL)\
        html += '<div class="lndd-p-lucthan">' + pal.loaiThanName + '</div>';\
\
        // Th\'e1\'ba\'a7n S\uc0\u258 \'a1t \'e2\'80\'94 V\u258 \'b2ng Th\u258 \'a1i Tu\'e1\'ba\'bf (line 4)\
        if (pal.thanSat && pal.thanSat.length > 0) \{\
            html += '<div class="lndd-p-thansat">' + pal.thanSat.join(', ') + '</div>';\
        \}\
\
        // KV badge\
        if (isKV) \{\
            html += '<div class="lndd-p-kv-badge">Kh\uc0\u258 \'b4ng Vong</div>';\
        \}\
\
        html += '</div>';\
        return html;\
    \}\
\
    function isKongWang(r, diBanIdx) \{\
        var kv = r.kongWang.day;\
        return kv[0] === diBanIdx || kv[1] === diBanIdx;\
    \}\
\
    function isTamTruyenPalace(r, diBanIdx) \{\
        for (var i = 0; i < 3; i++) \{\
            if (r.tamTruyen[i].branch === diBanIdx) return true;\
        \}\
        return false;\
    \}\
\
    // ============================================================\
    //  CENTER CELLS (4 cells in middle \'e2\'80\'94 T\'e1\'bb\'a9 Kh\uc0\u258 \'b3a + Tam Truy\'e1\'bb\u129 n + info)\
    // ============================================================\
\
    function renderCenterCell(r, cellId) \{\
        var html = '<div class="lndd-center-cell lndd-center-' + cellId + '">';\
\
        if (cellId === 'c1') \{\
            // Th\'e1\'bb\uc0\u157 i Kh\u258 \'b3a \'e2\'80\'94 Four Pillars mini\
            html += '<div class="lndd-center-title">TH\'e1\'bb\'9cI KH\uc0\u258 \'93A</div>';\
            html += '<table class="lndd-tk-table">';\
            html += '<tr><th>N\'c4\'82M</th><th>TH\uc0\u258 \u129 NG</th><th>NG\u258 \'80Y</th><th>GI\'e1\'bb\'9c</th></tr>';\
            var fp = r.fourPillars;\
            html += '<tr><td>' + LNDD_Engine.formatCanChi(fp.year) + '</td>';\
            html += '<td>' + LNDD_Engine.formatCanChi(fp.month) + '</td>';\
