            'Mang Ch\'e1\'bb\'a7ng':4,'H\'e1\'ba\'a1 Ch\uc0\u258 \'ad':4,'Ti\'e1\'bb\'83u Th\'e1\'bb\'ad':5,'\'c4\u144 \'e1\'ba\'a1i Th\'e1\'bb\'ad':5,\
            'L\'e1\'ba\'adp Thu':6,'X\'e1\'bb\'ad Th\'e1\'bb\'ad':6,'B\'e1\'ba\'a1ch L\'e1\'bb\'99':7,'Thu Ph\uc0\u258 \'a2n':7,\
            'H\uc0\u258 \'a0n L\'e1\'bb\'99':8,'S\'c6\'b0\'c6\'a1ng Gi\u258 \'a1ng':8,'L\'e1\'ba\'adp \'c4\u144 \u258 \'b4ng':9,'Ti\'e1\'bb\'83u Tuy\'e1\'ba\'bft':9,\
            '\'c4\uc0\u144 \'e1\'ba\'a1i Tuy\'e1\'ba\'bft':10,'\'c4\u144 \u258 \'b4ng Ch\u258 \'ad':10,'Ti\'e1\'bb\'83u H\u258 \'a0n':11,'\'c4\u144 \'e1\'ba\'a1i H\u258 \'a0n':11\
        \};\
        var monthNum = termToMonth[solarTermName] || 0;\
        var chiIdx = (monthNum + 2) % 12;\
        var startCan = [2, 4, 6, 8, 0, 2, 4, 6, 8, 0];\
        var canIdx = (startCan[yearCan] + monthNum) % 10;\
        return \{ can: canIdx, chi: chiIdx, jiaZi: getJiaZiIndex(canIdx, chiIdx) \};\
    \}\
\
    function getTuanHead(jiaZiIdx) \{ return Math.floor(jiaZiIdx / 10) * 10; \}\
\
    function getKongWang(jiaZiIdx) \{\
