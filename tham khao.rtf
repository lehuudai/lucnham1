    // ============================================================\
    //  RAW TEXT FOR AI\
    // ============================================================\
    function renderRawText(r) \{\
        var text = LNDD_Engine.generateRawText(r);\
        var html = '<div class="lndd-rawtext">';\
        html += '<h3>\uc0\u273 \'9f\'93\'8b D\'e1\'bb\'af li\'e1\'bb\'87u \'c4\'91\'e1\'bb\'83 h\'e1\'bb\u143 i AI lu\'e1\'ba\'adn gi\'e1\'ba\'a3i</h3>';\
        html += '<p class="lndd-rawtext-desc">Sao ch\uc0\u258 \'a9p n\'e1\'bb\'99i dung d\'c6\'b0\'e1\'bb\'9bi \'c4\'91\u258 \'a2y v\u258 \'a0 d\u258 \'a1n v\u258 \'a0o AI (ChatGPT, Gemini, ...) \'c4\'91\'e1\'bb\'83 nh\'e1\'ba\'adn lu\'e1\'ba\'adn gi\'e1\'ba\'a3i chi ti\'e1\'ba\'bft.</p>';\
        html += '<div class="lndd-rawtext-box" id="lndd-rawtext-content">' + text.replace(/\\n/g, '<br>').replace(/\\*\\*([^*]+)\\*\\*/g, '<strong>$1</strong>') + '</div>';\
        html += '<button class="lndd-btn-copy" onclick="lnddCopyRawText()">\uc0\u273 \'9f\'93\'8b Sao Ch\u258 \'a9p</button>';\
        html += '</div>';\
        return html;\
    \}\
\
