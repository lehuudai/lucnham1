\
    function getYearCanChi(year, month, day, hour, minute) \{\
        hour = hour || 0; minute = minute || 0;\
        var terms = KMDG_Solar.getAllTerms(year);\
        var jd = KMDG_Solar.dateToJD(year, month, day, hour, minute);\
        var lapXuan = null;\
